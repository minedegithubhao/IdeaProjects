<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartdrm.mapper.User.UserMapper">

    <select id="getUserById" parameterType="java.lang.String" resultType="com.smartdrm.entity.user.User">
        select * from sys_user where id = #{id};
    </select>

    <select id="getUsers" parameterType="com.smartdrm.entity.user.UserParam" resultType="com.smartdrm.entity.user.User">
        select * from sys_user
        <where>
            <if test="username != null and username != ''">
                and username = #{username}
            </if>
            <if test="realname != null and realname != ''">
                and realname = #{realname}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
        limit ${(page-1)*rows},${rows};
    </select>

    <select id="getUserCount" parameterType="com.smartdrm.entity.user.UserParam" resultType="java.lang.Integer">
        select count(*) from sys_user
        <where>
            <if test="username != null and username != ''">
                and username = #{username}
            </if>
            <if test="realname != null and realname != ''">
                and realname = #{realname}
            </if>
            <if test="status != null and status != ''">
                and status = #{status}
            </if>
        </where>
    </select>

    <insert id="insertUser" parameterType="com.smartdrm.entity.user.User">
        insert into sys_user(id,username,realname,password,status,LOGIN_STATUS)
        values(#{id},#{username},#{realname},#{password},#{status},#{loginStatus})
    </insert>

    <delete id="deleteUserById" parameterType="java.lang.String">
        delete from SYS_USER where ID = #{id}
    </delete>

    <update id="updateUser" parameterType="com.smartdrm.entity.user.User">
        update SYS_USER
        set USERNAME = #{username},
            REALNAME = #{realname},
            STATUS = #{status}
        where ID = #{id}
    </update>

    <select id="getUserByName" parameterType="java.lang.String" resultType="com.smartdrm.entity.user.User">
        select * from sys_user where USERNAME = #{username};
    </select>
</mapper>
