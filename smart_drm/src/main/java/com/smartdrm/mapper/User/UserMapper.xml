<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.smartdrm.mapper.User.UserMapper">

    <select id="getUserById" parameterType="java.lang.String" resultType="com.smartdrm.entity.User">
        select * from sys_user where id = #{id};
    </select>

    <select id="getUsers" parameterType="java.lang.String" resultType="com.smartdrm.entity.User">
        select * from sys_user
    </select>

</mapper>
